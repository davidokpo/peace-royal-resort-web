{

  "name": "monorepo",

  "version": "0.0.0",

  "private": true,

  "scripts": {
    "dev": "concurrently --kill-others --raw \"pnpm --filter web dev\" \"pnpm --filter api dev\"",
    "build": "pnpm --filter web build",
    "vercel-build": "pnpm --filter web build",
    "start": "node apps/api/src/main.js",
    "lint": "pnpm --filter web lint && pnpm --filter api lint"
  },

  "devDependencies": {

    "concurrently": "^9.1.2"

  },

  "workspaces": [

    "apps/*"

  ]

}