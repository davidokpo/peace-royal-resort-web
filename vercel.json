{
  "version": 2,
  "buildCommand": "npm run vercel-build",
  "outputDirectory": "dist/apps/web",
  "functions": {
    "api/src/main.js": {
      "runtime": "nodejs20.x"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/src/main.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
