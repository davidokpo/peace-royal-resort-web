{
  "version": 2,
  "public": true,
  "functions": {
    "api/src/main.js": {
      "runtime": "nodejs20.x"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/src/main.js"
    },
    {
      "source": "/(.*)",
      "destination": "/apps/web/index.html"
    }
  ]
}